# Copy this file to .env.local and fill in your own Neon connection string.
# Get it from the Neon console (Dashboard -> Connect) or `neonctl connection-string --pooled`.
# Use the POOLED connection string (host contains "-pooler") for serverless deployments.
DATABASE_URL="postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require&channel_binding=require"
